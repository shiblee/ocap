# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ocap_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ocap_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Clickhouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123

# App Settings
APP_NAME=OCAP
DEBUG=False
SECRET_KEY=generate_a_secure_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# ── SMTP / Bulk Email ─────────────────────────────────────────────────
# Supported providers: Gmail, SendGrid, Mailgun, AWS SES, SMTP2GO, etc.
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your@gmail.com
MAIL_FROM_NAME=OCAP

# Bulk tuning (optional — defaults shown)
MAIL_RATE_LIMIT_DELAY=0.1
MAIL_MAX_RETRIES=3
MAIL_RETRY_BACKOFF=2.0
MAIL_CONNECTION_TIMEOUT=30

# Provider notes:
# Gmail:     Enable 2FA → App Password at myaccount.google.com/apppasswords (daily limit ~500)
# SendGrid:  MAIL_HOST=smtp.sendgrid.net  MAIL_USERNAME=apikey  MAIL_PASSWORD=SG.xxxx
# AWS SES:   MAIL_HOST=email-smtp.<region>.amazonaws.com  (verify domain in SES first)
# Mailgun:   MAIL_HOST=smtp.mailgun.org  MAIL_USERNAME=postmaster@yourdomain.mailgun.org
